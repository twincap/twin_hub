# Copy this file to frontend/.env.local for local Next.js development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Fill these only when a utility actually needs Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Media Downloader
MEDIA_DOWNLOADER_ENABLED=false
YT_DLP_PATH=yt-dlp
YT_DLP_JS_RUNTIME=node
YT_DLP_NO_OUTPUT_TIMEOUT_MS=1800000
MEDIA_DOWNLOAD_DIR=

# Media Converter
MEDIA_CONVERTER_ENABLED=false
FFMPEG_PATH=ffmpeg
MEDIA_CONVERT_DIR=
MEDIA_CONVERT_MAX_MB=512
